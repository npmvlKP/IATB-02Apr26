# IATB Environment Variables
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to version control

# ===========================================
# Trading Platform API Keys
# ===========================================

# Interactive Brokers (IBKR)
IBKR_CLIENT_ID=your_client_id
IBKR_CLIENT_SECRET=your_client_secret
IBKR_ACCOUNT_ID=your_account_id
IBKR_GATEWAY_URL=https://api.ibkr.com/v1/portal

# Alpaca
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # Use paper for testing

# TD Ameritrade
TD_AMERITRADE_CLIENT_ID=your_consumer_key
TD_AMERITRADE_REFRESH_TOKEN=your_refresh_token
TD_AMERITRADE_ACCOUNT_ID=your_account_id

# Zerodha (Kite Connect)
# Note: KITE_* environment variables are supported as aliases for ZERODHA_* variables
ZERODHA_API_KEY=replace_with_your_zerodha_api_key
ZERODHA_API_SECRET=replace_with_your_zerodha_api_secret
ZERODHA_TOTP_SECRET=optional_your_totp_secret_for_2fa
ZERODHA_REQUEST_TOKEN=replace_me_after_oauth_login
ZERODHA_ACCESS_TOKEN=optional_existing_access_token

# Binance
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key
BINANCE_TESTNET=true  # Set to false for live trading

# Coinbase
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET=your_coinbase_api_secret
COINBASE_PASSPHRASE=your_coinbase_passphrase

# Kraken
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_SECRET_KEY=your_kraken_api_secret

# ===========================================
# Data Provider API Keys
# ===========================================

# Alpha Vantage
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Polygon.io
POLYGON_API_KEY=your_polygon_api_key

# Quandl
QUANDL_API_KEY=your_quandl_api_key

# IEX Cloud
IEX_API_KEY=your_iex_api_key

# Finnhub
FINNHUB_API_KEY=your_finnhub_api_key

# ===========================================
# Notification Services
# ===========================================

# Slack
SLACK_WEBHOOK_URL=your_slack_webhook_url
SLACK_CHANNEL=#trading-alerts

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=alert_recipient@email.com

 # ===========================================
 # Application Configuration
 # ===========================================

 # Environment
 ENVIRONMENT=development  # development, staging, production
 LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

 # Live Trading Safety Gate (ALL THREE MUST BE TRUE FOR LIVE TRADING)
 LIVE_TRADING_ENABLED=false  # Layer 1: Environment variable (default: false for safety)
 # Note: For live trading, you also need:
 # 1. Config setting: live_trading_enabled=true
 # 2. CLI flag: --enable-live-trading

# Database
DATABASE_URL=sqlite:///./iatb.db  # Or postgresql://user:password@localhost:5432/iatb

# Redis (for caching and pub/sub)
REDIS_URL=redis://localhost:6379/0

# Trading Settings
MAX_POSITION_SIZE=10000
RISK_PER_TRADE=0.02  # 2% of portfolio per trade
MAX_DAILY_LOSS=500  # Maximum daily loss in USD
TRADING_HOURS_START=09:30
TRADING_HOURS_END=16:00
TIMEZONE=America/New_York

# Order Settings
ORDER_TYPE=market  # market, limit, stop
ORDER_VALIDITY=day  # day, gtc, ioc, fok
SLIPPAGE_TOLERANCE=0.01  # 1% slippage tolerance