# Zerodha Broker Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Broker OAuth 2FA Verification
BROKER_OAUTH_2FA_VERIFIED=false

# Zerodha API Credentials
# Get these from https://kite.zerodha.com/connect/api
ZERODHA_API_KEY=your_api_key_here
ZERODHA_API_SECRET=your_api_secret_here

# Request Token (temporary, obtained during OAuth flow)
ZERODHA_REQUEST_TOKEN=
ZERODHA_REQUEST_TOKEN_DATE_UTC=

# Access Token (obtained after OAuth flow)
ZERODHA_ACCESS_TOKEN=
ZERODHA_ACCESS_TOKEN_DATE_UTC=

# TOTP Secret for 2FA (optional, for automated re-login)
# Get this from your authenticator app (e.g., Google Authenticator)
ZERODHA_TOTP_SECRET=
